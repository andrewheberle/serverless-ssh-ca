{
	"name": "@andrewheberle/serverless-ssh-ca",
	"version": "0.17.15",
	"description": "A serverless SSH CA built on Cloudflare Workers",
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"src"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"coverage": "vitest run --coverage",
		"lint": "eslint",
		"prepublishOnly": "npm run build",
		"release": "release-it",
		"release:ci": "npm run release:patch",
		"release:ci:major": "release-it major --ci",
		"release:ci:minor": "release-it minor --ci",
		"release:ci:patch": "release-it patch --ci",
		"release:dryrun": "release-it --dry-run",
		"schema": "node --require tsx/cjs scripts/export-schema.cjs",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@andrewheberle/ts-slog": "^1.3.0",
		"@cloudflare/workers-types": "^4.20260528.1",
		"chanfana": "^3.0.0",
		"hono": "^4.10.6",
		"itty-time": "^2.0.2",
		"jose": "^6.0.12",
		"workers-qb": "^1.14.0",
		"sshpk": "^1.18.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/sshpk": "^1.17.4",
		"@vitest/coverage-v8": "^4.1.7",
		"eslint": "^10.4.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.7"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrewheberle/serverless-ssh-ca.git"
	},
	"homepage": "https://github.com/andrewheberle/serverless-ssh-ca#readme",
	"bugs": {
		"url": "https://github.com/andrewheberle/serverless-ssh-ca/issues"
	},
	"author": "Andrew Heberle",
	"license": "Apache-2.0",
	"release-it": {
		"git": false,
		"npm": {
			"publish": true,
			"skipChecks": true
		}
	}
}
