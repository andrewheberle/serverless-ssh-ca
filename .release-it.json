{
	"$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
	"git": {
		"requiredBranch": "main",
		"commitMessage": "chore(release): v${version}",
		"tagName": "v${version}"
	},
	"hooks": {
		"before:init": [ "git pull", "npm run test" ],
		"after:bump": "npx auto-changelog -p"
	},
	"github": {
		"autoGenerate": true,
		"release": true,
		"releaseName": "v${version}"
	},
	"npm": {
		"publish": true,
		"skipChecks": true
	}
}
