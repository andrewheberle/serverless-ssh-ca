{
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"test": "npm run test -w packages/core",
		"test:workers": "npm run build -w packages/core && npm run test -w packages/workers-integration",
		"release": "npm run release --workspaces && release-it"
	},
	"devDependencies": {
		"@release-it/bumper": "^7.0.6",
		"auto-changelog": "^2.5.1",
		"release-it": "^20.0.1"
	},
	"release-it": {
		"git": {
			"requiredBranch": "main",
			"commitMessage": "chore(release): v${version}",
			"tagName": "v${version}",
			"requireCleanWorkingDir": false
		},
		"github": {
			"autoGenerate": true,
			"release": true,
			"releaseName": "v${version}"
		},
		"hooks": {
			"hooks": {
				"before:init": [
					"npm run test",
					"npm run test:workers"
				]
			},
			"after:bump": "npx auto-changelog -p"
		},
		"npm": {
			"publish": false
		}
	}
}
