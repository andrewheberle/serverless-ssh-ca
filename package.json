{
	"private": true,
	"version": "0.17.15",
	"workspaces": [
		"packages/core",
		"packages/workers-integration"
	],
	"scripts": {
		"build": "npm run build --workspaces --if-present",
		"cf-typegen": "npm run cf-typegen --workspaces --if-present",
		"coverage": "npm run coverage --workspaces --if-present",
		"dev": "npm run build && npm run dev --workspaces --if-present",
		"release": "npm run release --workspaces --if-present && release-it",
		"release:ci": "npm run release:ci --workspaces --if-present && release-it --ci",
		"release:dryrun": "npm run release:dryrun --workspaces --if-present && release-it --dry-run",
		"schema": "npm run schema --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"test:workers": "npm run test:workers --workspaces --if-present"
	},
	"devDependencies": {
		"@release-it/bumper": "^7.0.6",
		"auto-changelog": "^2.5.1",
		"release-it": "^20.0.1"
	},
	"release-it": {
		"git": {
			"requiredBranch": "main",
			"commitMessage": "chore(release): v${version}",
			"tagName": "v${version}",
			"requireCleanWorkingDir": false
		},
		"github": {
			"autoGenerate": true,
			"release": true,
			"releaseName": "v${version}"
		},
		"hooks": {
			"after:bump": "npx auto-changelog -p"
		}
	},
	"npm": {
		"publish": false
	}
}
