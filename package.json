{
	"name": "@andrewheberle/serverless-ssh-ca",
	"version": "0.17.11",
	"description": "A serverless SSH CA built on Cloudflare Workers",
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"coverage": "vitest run --coverage",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "npm run build",
		"release": "release-it"
	},
	"dependencies": {
		"@andrewheberle/ts-slog": "^1.3.0",
		"@cloudflare/actors": "^0.0.1-beta.6",
		"@cloudflare/workers-types": "^4.20260528.1",
		"chanfana": "^3.0.0",
		"hono": "^4.10.6",
		"itty-time": "^2.0.2",
		"jose": "^6.0.12",
		"sshpk": "^1.18.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/sshpk": "^1.17.4",
		"@vitest/coverage-istanbul": "^4.1.7",
		"auto-changelog": "^2.5.1",
		"release-it": "^20.0.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.0",
		"vitest": "^4.1.7"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/andrewheberle/serverless-ssh-ca.git"
	},
	"homepage": "https://github.com/andrewheberle/serverless-ssh-ca#readme",
